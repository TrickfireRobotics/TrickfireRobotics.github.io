---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import DocCard from "../components/DocCard.astro";
import Footer from "../components/Footer.astro";
import { getRepos } from "../data/repos";

const repos = getRepos();
---

<BaseLayout
    title="TrickFire Robotics Docs"
    description="Central documentation portal for TrickFire Robotics. Find guides for Gazebo simulations, the URC codebase, and more."
>
    <Header />
    <main>
        <Hero />
        <section class="docs">
            <h2>Documentation</h2>
            {
                repos.length > 0 ? (
                    <div class="card-grid">
                        {repos.map((repo) => (
                            <DocCard
                                title={repo.name}
                                description={repo.description}
                                href={repo.href}
                            />
                        ))}
                    </div>
                ) : (
                    <p class="empty">No docs sites published yet - check back soon.</p>
                )
            }
        </section>
    </main>
    <Footer />
</BaseLayout>

<style>
    .docs {
        max-width: 72rem;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 3rem;
    }

    h2 {
        font-size: 0.85rem;
        color: var(--tf-text-muted);
        letter-spacing: 0.08em;
        margin-bottom: 1.25rem;
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
        gap: 1.25rem;
    }

    .empty {
        color: var(--tf-text-muted);
        padding: 1.5rem 0;
    }
</style>
