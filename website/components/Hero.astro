---

---

<section class="hero">
    <img src="/logo.png" alt="TrickFire Robotics Logo" class="hero-logo" />
    <h1>TrickFire Robotics</h1>
    <p class="tagline">Documentation Portal</p>
    <p class="description">Central hub for all TrickFire Robotics technical documentation.</p>
</section>

<style>
    .hero {
        text-align: center;
        padding: 4rem 1.5rem 2rem;
    }

    .hero-logo {
        width: auto;
        height: min(35vh, 16rem);
        max-width: 100%;
        object-fit: contain;
        display: block;
        margin: 0 auto 2rem;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        color: var(--tf-green);
        margin-bottom: 0.25rem;
    }

    .tagline {
        font-family: var(--tf-font-heading);
        font-weight: 600;
        font-size: clamp(1.1rem, 2.5vw, 1.5rem);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--tf-pink);
        margin-bottom: 1rem;
    }

    .description {
        color: var(--tf-text-muted);
        font-size: 1.05rem;
        max-width: 36rem;
        margin: 0 auto;
    }
</style>
