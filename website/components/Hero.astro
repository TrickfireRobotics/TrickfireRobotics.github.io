---

---

<section class="hero">
    <img src="/logo.png" alt="TrickFire Robotics Logo" class="hero-logo" />
    <div class="hero-text">
        <h1>TrickFire Robotics Docs</h1>
        <p class="description">Central hub for all TrickFire Robotics technical documentation.</p>
    </div>
</section>

<style>
    .hero {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        max-width: 72rem;
        margin: 0 auto;
        padding: 3rem 1.5rem 1.5rem;
    }

    .hero-logo {
        width: auto;
        height: 4rem;
        max-width: 100%;
        object-fit: contain;
        flex-shrink: 0;
    }

    h1 {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        color: var(--tf-white);
        margin-bottom: 0.25rem;
    }

    .description {
        color: var(--tf-text-muted);
        font-size: 1rem;
        max-width: 36rem;
    }

    @media (max-width: 32rem) {
        .hero {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
