{
    "name": "trickfire-docs",
    "version": "0.1.0",
    "description": "A TrickFire robotics documentation framework wrapping Astro Starlight",
    "license": "MIT",
    "author": "TrickFire Robotics",
    "type": "module",
    "bin": {
        "trickfire-docs": "./dist/cli.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "internal",
        "scaffold"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsx src/cli.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "release:dry-run": "semantic-release --dry-run --no-ci",
        "prepack": "cp ../README.md ./README.md"
    },
    "devDependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/node": "^26.0.1",
        "semantic-release": "^25.0.5",
        "tsup": "^8.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@astrojs/starlight": "^0.41.1",
        "astro": "^7.0.3",
        "chokidar": "^5.0.0",
        "jiti": "^2.7.0",
        "sharp": "^0.35.2"
    }
}
