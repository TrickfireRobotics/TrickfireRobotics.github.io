{
    "name": "trickfire-docs",
    "version": "0.1.0",
    "description": "A TrickFire robotics documentation framework wrapping Astro Starlight",
    "license": "MIT",
    "author": "TrickFire Robotics",
    "type": "module",
    "bin": {
        "trickfire-docs": "./dist/cli.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "internal",
        "scaffold"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsx src/cli.ts",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "check": "pnpm lint && pnpm format:check && pnpm typecheck",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": "prettier --write"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^9.0.0",
        "@types/node": "^26.0.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "tsup": "^8.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@astrojs/starlight": "^0.41.1",
        "astro": "^7.0.3",
        "chokidar": "^5.0.0",
        "jiti": "^2.7.0",
        "sharp": "^0.35.2"
    }
}
