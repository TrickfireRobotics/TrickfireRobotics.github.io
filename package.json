{
    "name": "trickfire-docs-portal",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p framework/tsconfig.json",
        "check": "pnpm lint && pnpm format:check && pnpm typecheck",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.astro": "prettier --write",
        "*.{json,md,yml,yaml}": "prettier --write"
    },
    "dependencies": {
        "astro": "^6.1.7"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^9.0.0",
        "@types/node": "^26.0.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "prettier-plugin-astro": "^0.14.1",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0"
    }
}
