{
    "name": "my-tool",
    "version": "0.1.0",
    "description": "Example CLI package scaffold.",
    "license": "MIT",
    "author": "TrickFire Robotics",
    "type": "module",
    "bin": {
        "my-tool": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsx src/cli.ts",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "check": "pnpm lint && pnpm format:check && pnpm typecheck",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": "prettier --write"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^9.0.0",
        "@types/node": "^26.0.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "tsup": "^8.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.1.9"
    }
}
