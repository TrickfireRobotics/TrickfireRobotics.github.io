---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import DocCard from '../components/DocCard.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
    title="TrickFire Robotics Docs"
    description="Central documentation portal for TrickFire Robotics. Find guides for Gazebo simulations, the URC codebase, and more."
>
    <Header />
    <main>
        <Hero />
        <section class="docs">
            <h2>Documentation</h2>
            <div class="card-grid">
                <DocCard
                    title="Gazebo Simulations"
                    description="Setup guides, simulation tutorials, and deep dives for the TrickFire ROS2/Gazebo simulation environment."
                    href="/gazebo-simulations/"
                />
                <DocCard
                    title="URC Codebase"
                    description="Documentation for the TrickFire Robotics URC competition codebase."
                    href="/trickfire-urc/"
                />
            </div>
        </section>
    </main>
    <Footer />
</BaseLayout>

<style>
    .docs {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2rem 1.5rem;
    }

    h2 {
        font-size: 1.5rem;
        color: var(--tf-pink);
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
        gap: 1.5rem;
        max-width: 48rem;
        margin: 0 auto;
    }
</style>
