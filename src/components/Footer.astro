---
const year = new Date().getFullYear();
---

<footer>
    <div class="footer-content">
        <p class="copyright">&copy; {year} TrickFire Robotics</p>
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid var(--tf-border);
        padding: 2rem 1.5rem;
        margin-top: 4rem;
    }

    .footer-content {
        max-width: 72rem;
        margin: 0 auto;
        text-align: center;
    }
    .copyright {
        color: var(--tf-text-muted);
        font-size: 0.8rem;
    }
</style>
